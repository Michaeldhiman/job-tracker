# =========================================================================
# Snap Job Backend Environment Variables Template
# Copy this file to '.env' and fill in your custom credentials.
# =========================================================================

# --- Node Settings ---
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000

# --- Database ---
# MongoDB connection URI (e.g. Local MongoDB or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/job-tracker

# --- Security & Auth ---
# Strong secret key used for signing JWT access tokens
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random

# --- CORS & Redirects ---
# URL of your frontend application (e.g. for CORS validation and redirect completion)
FRONTEND_URL=http://localhost:3000
# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Request Limits ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# --- Google Calendar API & OAuth 2.0 ---
# Google Client ID from Google Cloud Console credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Google Client Secret from Google Cloud Console credentials
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Google Redirect URI Callback (must match Authorized Redirect URIs in Google Cloud Console exactly)
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/auth/callback
# Google Redirect URI Callback for User Login/Register (must match in Google Cloud Console)
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# --- Resend Email Service ---
# API key from https://resend.com/api-keys
# Leave empty to run in mock/console-log mode (safe for development)
RESEND_API_KEY=re_your_resend_api_key_here
# Sender email address (must be from a verified domain in your Resend account)
RESEND_FROM=noreply@snapjob.io
# Recipient for contact form submissions
CONTACT_EMAIL=admin@snapjob.io

# --- Cloudinary Settings ---
# Cloudinary cloud name for storing uploaded resumes
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# Cloudinary API key
CLOUDINARY_API_KEY=your_cloudinary_api_key
# Cloudinary API secret
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Scheduler ---
SCHEDULER_CRON_EXPRESSION=*/15 * * * *
SCHEDULER_TIMEZONE=UTC
